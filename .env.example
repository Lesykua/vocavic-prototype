# Get a free token at https://huggingface.co/settings/tokens
# Requires access to openai/whisper-large-v3 (free tier is fine)
HF_API_TOKEN=

# Connect a Neon Postgres database from the Vercel dashboard's Storage tab —
# it auto-populates this on deploy. For local dev, pull it with
# `vercel env pull .env.local` or paste a Neon connection string directly.
# (POSTGRES_URL also works if that's what your integration named it.)
# NOTE: /api/notes and /api/analytics are unauthenticated — anyone with the
# deployed URL can read or write shift notes. Fine for a closed prototype
# link, not for a public rollout.
DATABASE_URL=
